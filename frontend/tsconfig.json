{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": [
    "src/main.tsx",
    "src/vite-env.d.ts",
    "src/app/**/*.tsx",
    "src/components/**/*.tsx",
    "src/features/home/**/*.tsx",
    "src/features/catalog/**/*.tsx",
    "src/features/services/**/*.tsx",
    "src/features/gracias/**/*.tsx",
    "src/features/admin/**/*.tsx",
    "src/lib/**/*.ts",
    "src/types.ts",
    "src/styles/**/*.css"
  ]
}
